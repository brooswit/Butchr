{
  // public/ CANNOT share the root tsconfig.json, and the blocker is `lib`, not JSX (RFC §5.5,
  // measured in §13.2). public/ needs "DOM" to see `document`. Adding "DOM" to the root config
  // changes src/'s type universe in BOTH directions: it BREAKS src/channel.ts's
  // `for await (const chunk of Bun.stdin.stream())` (lib.dom's ReadableStream is not
  // async-iterable — TS2504) and it MASKS src/mcp.ts's `await req.json()` (`unknown` under
  // bun-types, `any` under lib.dom's Request). A shared config is wrong in both directions.
  //
  // The split is also a feature. With "types": [] here, `Bun.file(…)` in a browser module is a
  // compile error; with no "DOM" in the root config, `document.title` in src/ is a compile error.
  // Each tree is confined to its own globals.
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    // No bun globals in browser code — this is what makes Bun.file() a compile error here.
    "types": [],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    // NO `allowJs`. RFC Phase 4e deleted the last vanilla module, so public/ is 15 `.ts` + 15 `.tsx`
    // and there is no JavaScript left to allow. Through Phases 1-3 it was set WITHOUT `checkJs`,
    // which meant an orphan .js file's TYPE errors went unreported — exactly as strong as the
    // per-file `bun build` parse loop it replaced, and no stronger. That caveat is now moot: every
    // file `include` matches is fully typechecked, orphan or not, reachable from an entry point or
    // not. `test/no-dangerous-html.test.ts` (f) is what keeps a `.js` from quietly reappearing and
    // slipping back out of coverage.
    //
    // Permits `import { StatusChip } from "../components/chips.tsx"` — the explicit extension. It is
    // no longer strictly REQUIRED: it existed because `components/chips.js` (vanilla) sat next to
    // `components/chips.tsx` (React) and `"./chips.js"` resolved to the FIRST of those under both
    // `tsc` and `bun build`, leaving no specifier that reached the `.tsx`. The `.js` twins are gone,
    // so a `.js` specifier now resolves to the `.tsx` — but App.tsx and six test files still spell
    // the extension out, and rewriting those is a rename, not a deletion. Legal here because
    // `noEmit` is set; the flag is rejected when tsc emits.
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    // Explicit, per RFC §2.4. Omitting it works only because bun's DEFAULT is the automatic
    // runtime; `tsc` needs it stated to typecheck JSX at all. Never set "react" (the classic
    // transform) — bun would emit React.createElement into files that never import React, exit
    // 0, and throw at runtime.
    "jsx": "react-jsx"
  },
  // Side-effect CSS imports (`import "@launchpad-ui/tokens/index.css"`) need NO
  // `declare module "*.css"` shim — TS only demands a declaration for a BINDING import. Do not
  // add a declarations.d.ts; it is the obvious-looking move and it is unnecessary.
  "include": ["public"]
}
