{
  "name": "butchr",
  "version": "0.9.126",
  "description": "Agent task harness on top of herdr — directories are workspaces, tasks are git worktrees.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "butchr": "bin/butchr"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "start:supervised": "bash scripts/supervise.sh",
    "dev": "bun --watch run src/index.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
