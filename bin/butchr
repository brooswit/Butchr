#!/usr/bin/env bun
// butchr — operator CLI for the butchr REST API.
//
// A dependency-free REST client (bun/node stdlib `fetch` only). It maps each
// subcommand onto an existing server route in src/server.ts — it adds NO server
// logic of its own. Talks to http://127.0.0.1:47800 by default; override with the
// BUTCHR_URL env var.
//
// Exit codes: 0 on success, 1 on any API/usage/connection error (the message is
// printed to stderr). Pass --json on any command for the raw API payload.

import { runSelftest } from "../src/selftest.ts";

const BASE = (process.env.BUTCHR_URL || "http://127.0.0.1:47800").replace(/\/+$/, "");

const HELP = `butchr — operator CLI for the butchr REST API

USAGE
  butchr <command> [args] [--json]

COMMANDS
  health                          Server health snapshot (exit 1 if degraded).
  dashboard                       Cross-project rollup: per-workspace active /
                                    review / needs-attention / failed counts.
  gate <workspace> [--set "<cmd>"]      Show or update a workspace's build/test gate
       [--clear]                    command. --set updates it; --clear reverts to
                                    the default; no flag prints the effective one.
  ls [--workspace <id>] [--status <s>]  List tasks as a compact id/status/ci/tags table.
     [--tag a,b]                    Keep only tasks carrying any of the given tags.
     [--search <text>]              Full-text match on prompt/summary/review notes/id.
  new <workspace> -m <prompt>           Create a task in <workspace> (id or path).
      [--blocked-by id,id]          Start it blocked on the given task ids.
      [--tag a,b]                   Attach organizational labels (comma-separated).
      [--priority N]                Dispatch priority (higher = sooner; default 0).
      [--plan]                      Plan-preview gate: the agent proposes a plan and
                                    pauses for your approval before writing code.
      [--allowlist a,b]             File allowlist (glob/path entries, comma-separated):
                                    the CI gate FAILS if the diff strays outside it.
      [--bump patch|minor|major]    Declared semver bump applied at merge in a
                                    release_mode workspace (default patch; inert
                                    otherwise). A major bump needs confirm-major x2.
      [--template <name>]           Create from a template instead of -m; fill its
      [--var key=val ...]             {{placeholders}} with repeatable --var pairs.
  templates                       List the built-in task templates + placeholders.
  show <id>                       Task detail: status, ci, tags, summary, notes.
  approve <id>                    Approve a task in review (merges its branch).
  confirm-major <id>              Confirm a release_mode major-bump task's merge. The
                                    human DOUBLE-CONFIRM: run it TWICE consecutively
                                    (streak 0→1→2) to land the merge; any other action
                                    resets the streak. Approve alone only PARKS a major.
  reject <id> -m <note>           Send a reviewed task back for rework with a note.
  answer <id> -m <text>           Answer a task awaiting input (resumes the agent).
  plan-approve <id> [-m <text>]   Approve a plan-preview task's proposed plan (resumes the
                                    agent to implement; -m adds optional steering notes).
  plan-reject <id> -m <text>      Reject a proposed plan with required feedback; the agent
                                    revises and re-proposes (distinct from answer).
  spec <id> [-m <text>]           Submit the spec for an idea task (-m, or pipe stdin).
  requeue <id>                    Re-queue a failed/stuck task for a fresh dispatch.
  nudge <id> [-m <text>]          Nudge an idle agent: -m sends guidance, else 'continue'.
  block <id> --on id,id           Replace a task's blocked_by set (empty to clear).
  priority <id> <N>               Set a task's dispatch priority (higher = sooner).
  wait <id> --until <state>       Block until the task reaches <state> (e.g. in_review,
       [--timeout <sec>]            merged, idle); exits non-zero on a timeout or if the
       [--interval <sec>]           task reaches a DIFFERENT terminal state first.
  restart [--verify]              Restart the butchr server (POST /api/restart). --verify
          [--timeout <sec>]        blocks until it comes back healthy (db + tick green).
  selftest [--workspace <id|path>]      Smoke-test the FULL lifecycle with a throwaway
     [--merge] [--timeout <sec>]    probe in the sandbox (dispatch→review→cleanup).
                                    --merge also approves+merges then rolls it back.
  backups                         List local DB snapshots (newest first). OFFLINE.
  restore <file|latest> [--force] Restore the DB from a snapshot. OFFLINE — stop
                                    butchr first; --force skips the running check.

GLOBAL FLAGS
  --json        Print the raw JSON response instead of formatted output.
  --force       (restore) proceed even if a butchr server appears to be running.
  -h, --help    Show this help.

ENVIRONMENT
  BUTCHR_URL    Base URL of the butchr server (default ${BASE}).
`;

// ---- argument parsing -----------------------------------------------------

// Flags that consume the following token as their value. Everything else is a
// positional. Also supports the --flag=value form.
const VALUE_FLAGS = new Set(["--workspace", "--status", "-m", "--message", "--blocked-by", "--on", "--tag", "--priority", "--template", "--timeout", "--search", "--set", "--bump", "--allowlist", "--until", "--interval"]);

// Boolean flags: present → true, consume no following token.
const BOOLEAN_FLAGS = new Set(["--merge", "--clear", "--plan", "--verify"]);

function parseArgs(argv) {
  const positionals = [];
  const flags = {};
  for (let i = 0; i < argv.length; i++) {
    const tok = argv[i];
    if (tok === "--json") {
      flags.json = true;
    } else if (tok === "--force") {
      flags.force = true;
    } else if (tok === "-h" || tok === "--help") {
      flags.help = true;
    } else if (tok === "--var" || tok.startsWith("--var=")) {
      // --var is REPEATABLE (one `key=value` template variable each), so it
      // accumulates into an array rather than overwriting like the value flags.
      const val = tok.startsWith("--var=") ? tok.slice("--var=".length) : argv[++i];
      if (val === undefined) fail("flag --var needs a key=value");
      (flags.var ||= []).push(val);
    } else if (BOOLEAN_FLAGS.has(tok)) {
      flags[tok.replace(/^--/, "")] = true;
    } else if (tok.startsWith("--") && tok.includes("=")) {
      const eq = tok.indexOf("=");
      flags[tok.slice(2, eq)] = tok.slice(eq + 1);
    } else if (VALUE_FLAGS.has(tok)) {
      const val = argv[++i];
      if (val === undefined) fail(`flag ${tok} needs a value`);
      // Normalize aliases to a canonical key.
      const key = tok === "-m" ? "message" : tok.replace(/^--/, "");
      flags[key] = val;
    } else if (tok.startsWith("-")) {
      fail(`unknown flag: ${tok}`);
    } else {
      positionals.push(tok);
    }
  }
  return { positionals, flags };
}

/** Split a comma-separated id list into a clean array (drops blanks). */
function parseIdList(raw) {
  if (raw === undefined) return [];
  return String(raw)
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);
}

/** Turn the repeatable `--var key=value` entries into a {key: value} object. */
function parseVars(list) {
  const out = {};
  for (const entry of list || []) {
    const eq = String(entry).indexOf("=");
    if (eq < 0) fail(`--var must be key=value (got "${entry}")`);
    out[String(entry).slice(0, eq).trim()] = String(entry).slice(eq + 1);
  }
  return out;
}

/** Parse a dispatch-priority argument into an integer (the server re-validates). */
function parsePriority(raw) {
  const n = Number(raw);
  if (!Number.isInteger(n)) fail(`priority must be an integer, got "${raw}"`);
  return n;
}

// ---- HTTP -----------------------------------------------------------------

class ApiError extends Error {
  constructor(message, status) {
    super(message);
    this.status = status;
  }
}

async function api(method, path, body) {
  let res;
  try {
    res = await fetch(BASE + path, {
      method,
      headers: body !== undefined ? { "content-type": "application/json" } : undefined,
      body: body !== undefined ? JSON.stringify(body) : undefined,
    });
  } catch (e) {
    throw new ApiError(
      `could not reach butchr at ${BASE} — is it running? (${e.message})`,
    );
  }
  const text = await res.text();
  let data = null;
  if (text) {
    try {
      data = JSON.parse(text);
    } catch {
      data = text;
    }
  }
  if (!res.ok) {
    const msg =
      data && typeof data === "object" && data.error
        ? data.error
        : typeof data === "string" && data
          ? data
          : `HTTP ${res.status}`;
    throw new ApiError(msg, res.status);
  }
  return data;
}

// ---- helpers --------------------------------------------------------------

function fail(msg) {
  process.stderr.write(`butchr: ${msg}\n`);
  process.exit(1);
}

function printJson(data) {
  process.stdout.write(JSON.stringify(data, null, 2) + "\n");
}

/** Require the leading <id> positional, or fail with the standard usage message. */
function requireId(positionals, cmd) {
  const id = positionals[0];
  if (!id) fail(`${cmd}: missing <id>`);
  return id;
}

/**
 * Standard output tail shared by every command: print the raw API payload under
 * --json, otherwise write the pre-formatted `text`. Returns so callers can
 * `return emit(...)` to end the command.
 */
function emit(flags, data, text) {
  if (flags.json) {
    printJson(data);
    return;
  }
  process.stdout.write(text);
}

/** Render an array of objects as a fixed-width column table. */
function table(rows, columns) {
  if (rows.length === 0) return "(none)";
  const widths = columns.map((c) =>
    Math.max(c.header.length, ...rows.map((r) => String(c.get(r) ?? "").length)),
  );
  const line = (cells) =>
    cells.map((cell, i) => String(cell ?? "").padEnd(widths[i])).join("  ").trimEnd();
  const out = [line(columns.map((c) => c.header))];
  for (const r of rows) out.push(line(columns.map((c) => c.get(r))));
  return out.join("\n");
}

/** Compact CI cell from a task row: status, or "-" when CI hasn't run. */
function ciCell(t) {
  return t.ci_status ? t.ci_status : "-";
}

/**
 * Resolve a workspace argument to a registered workspace id. Accepts the id
 * directly, or a filesystem path that matches a registered workspace. Errors
 * (listing what's available) when nothing matches.
 */
async function resolveWorkspaceId(arg) {
  const dirs = await api("GET", "/api/workspaces");
  const byId = dirs.find((d) => d.id === arg);
  if (byId) return byId.id;
  const byPath = dirs.find((d) => d.path === arg);
  if (byPath) return byPath.id;
  const known = dirs.map((d) => `  ${d.id}  ${d.path}`).join("\n") || "  (no workspaces registered)";
  throw new ApiError(`no registered workspace matches "${arg}". Known workspaces:\n${known}`);
}

// ---- commands -------------------------------------------------------------

async function cmdHealth(flags) {
  // Health returns 503 (degraded) without an `error` body, so call fetch directly
  // and surface the snapshot either way rather than treating 503 as an API error.
  let res;
  try {
    res = await fetch(BASE + "/health");
  } catch (e) {
    throw new ApiError(`could not reach butchr at ${BASE} — is it running? (${e.message})`);
  }
  const body = await res.json();
  const t = body.tasks || {};
  const counts = Object.keys(t).length
    ? Object.entries(t).map(([k, v]) => `${k}=${v}`).join(" ")
    : "(none)";
  emit(
    flags,
    body,
    `status:   ${body.status}\n` +
      `version:  ${body.version}\n` +
      `uptime:   ${body.uptimeSec}s\n` +
      `db:       ${body.db?.ok ? "ok" : "DOWN"}\n` +
      `tick:     ${body.tick?.alive ? "alive" : "STALE"} (count=${body.tick?.count})\n` +
      `herdr:    ${body.herdr?.reachable ? "reachable" : "unreachable"}\n` +
      `attention:review=${body.needsAttention?.review ?? 0} failed=${body.needsAttention?.failed ?? 0}\n` +
      `tasks:    ${counts}\n`,
  );
  // Non-zero exit when the server reports degraded so scripts can gate on it.
  if (res.status !== 200) process.exit(1);
}

async function cmdDashboard(flags) {
  const d = await api("GET", "/api/dashboard");
  if (!d.workspaces.length) {
    return emit(flags, d, "(no workspaces registered)\n");
  }
  const out = table(d.workspaces, [
    { header: "WORKSPACE", get: (x) => x.label || x.path },
    { header: "ID", get: (x) => x.id },
    { header: "ACTIVE", get: (x) => x.active },
    { header: "REVIEW", get: (x) => x.review },
    { header: "ATTN", get: (x) => x.needsAttention },
    { header: "FAILED", get: (x) => x.failed },
  ]);
  const t = d.totals;
  return emit(
    flags,
    d,
    out +
      `\n\ntotals: ${t.workspaces} dirs · ${t.active} active · ${t.review} review · ` +
      `${t.needsAttention} need attention · ${t.failed} failed\n`,
  );
}

async function cmdGate(positionals, flags) {
  const dir = positionals[0];
  if (!dir) fail("gate: missing <workspace> (workspace id or path)");
  const dirId = await resolveWorkspaceId(dir);
  // --set and --clear are mutually exclusive; both update the gate command.
  if (flags.set !== undefined && flags.clear) {
    fail("gate: pass either --set or --clear, not both");
  }
  if (flags.set !== undefined || flags.clear) {
    const gate_cmd = flags.clear ? null : flags.set;
    const v = await api("PATCH", `/api/workspaces/${encodeURIComponent(dirId)}`, { gate_cmd });
    const shown = v.gate_cmd === null ? "(default)" : v.gate_cmd === "" ? "(disabled)" : v.gate_cmd;
    return emit(flags, v, `${dirId} gate_cmd = ${shown}\n`);
  }
  // No update flag — show the workspace's effective gate command (from the dashboard
  // rollup, which carries both the override and the resolved effective command).
  const d = await api("GET", "/api/dashboard");
  const entry = d.workspaces.find((x) => x.id === dirId);
  if (!flags.json && !entry) fail(`gate: workspace ${dirId} not found`);
  const overridden = entry && entry.gate_cmd !== null;
  return emit(
    flags,
    entry || null,
    entry
      ? `${dirId} gate_cmd: ${entry.effective_gate_cmd || "(disabled)"}` +
          `${overridden ? "" : "  (default — no per-workspace override)"}\n`
      : "",
  );
}

async function cmdLs(flags) {
  let dirIds;
  if (flags.workspace) {
    dirIds = [await resolveWorkspaceId(flags.workspace)];
  } else {
    const dirs = await api("GET", "/api/workspaces");
    dirIds = dirs.map((d) => d.id);
  }
  // --search <text> is a SERVER-SIDE full-text filter (?q=) over each task's
  // prompt/summary/review notes/id — the prompt lives in task.md on the server, so
  // matching it has to happen there, not in this client. Blank → no filter.
  const search = (flags.search ?? "").trim();
  const qs = search ? `?q=${encodeURIComponent(search)}` : "";
  let tasks = [];
  for (const id of dirIds) {
    const list = await api("GET", `/api/workspaces/${encodeURIComponent(id)}/tasks${qs}`);
    tasks.push(...list);
  }
  if (flags.status) tasks = tasks.filter((t) => t.status === flags.status);
  // --tag a,b keeps tasks carrying ANY of the given labels (OR semantics), matching
  // the webapp's tag filter. An empty --tag '' is a no-op.
  const wantTags = parseIdList(flags.tag);
  if (wantTags.length) {
    tasks = tasks.filter((t) => Array.isArray(t.tags) && t.tags.some((g) => wantTags.includes(g)));
  }
  return emit(
    flags,
    tasks,
    table(tasks, [
      { header: "ID", get: (t) => t.id },
      { header: "STATUS", get: (t) => (t.idle ? `${t.status}*` : t.status) },
      { header: "CI", get: (t) => ciCell(t) },
      { header: "TAGS", get: (t) => (t.tags && t.tags.length ? t.tags.join(",") : "-") },
    ]) + "\n",
  );
}

async function cmdNew(positionals, flags) {
  const dir = positionals[0];
  if (!dir) fail("new: missing <workspace> (workspace id or path)");
  // Validate the cheap flag args (the declared bump level) BEFORE any network call, so a
  // typo'd --bump fails fast without a round-trip. Inert outside a release_mode workspace.
  if (flags.bump !== undefined && !["patch", "minor", "major"].includes(flags.bump)) {
    fail(`new: --bump must be 'patch', 'minor', or 'major' (got "${flags.bump}")`);
  }
  const dirId = await resolveWorkspaceId(dir);
  const blockedBy = parseIdList(flags["blocked-by"]);
  const tags = parseIdList(flags.tag);
  // Optional file allowlist (comma-separated glob/path entries) — the CI gate fails a diff
  // that strays outside it. Omitted (empty) leaves the gate inert. Reuses parseIdList's
  // split/trim/drop-blanks (the list shape is identical, just different semantics).
  const allowlist = parseIdList(flags.allowlist);
  const reqBody = { blocked_by: blockedBy, tags, allowlist };
  // Optional dispatch priority — higher dispatches sooner; omit to default to 0.
  if (flags.priority !== undefined) reqBody.priority = parsePriority(flags.priority);
  // Optional plan-preview gate — the agent proposes a plan and pauses for operator
  // approval before writing any code (see the propose_plan MCP tool).
  if (flags.plan) reqBody.plan_preview = true;
  // Optional declared semver bump (validated above) — applied at merge in a release_mode
  // workspace (inert otherwise). Omitted unless given so the server defaults it to 'patch'
  // and a non-release_mode create is byte-identical. A major bump still needs confirm-major ×2.
  if (flags.bump !== undefined) reqBody.version_bump = flags.bump;
  if (flags.template) {
    // Create FROM a built-in template: the server renders its body with the given
    // --var key=value pairs substituted into the {{placeholders}}. Any unset
    // placeholder is left visible (as `{{name}}`) in the created prompt.
    reqBody.template = flags.template;
    reqBody.vars = parseVars(flags.var);
  } else {
    const prompt = flags.message;
    if (!prompt) fail("new: missing -m <prompt> (or --template <name>)");
    reqBody.prompt = prompt;
  }
  const task = await api(
    "POST",
    `/api/workspaces/${encodeURIComponent(dirId)}/tasks`,
    reqBody,
  );
  return emit(flags, task, `created ${task.id} (${task.status})\n`);
}

async function cmdTemplates(flags) {
  const tpls = await api("GET", "/api/templates");
  return emit(
    flags,
    tpls,
    table(tpls, [
      { header: "NAME", get: (t) => t.name },
      { header: "PLACEHOLDERS", get: (t) => (t.placeholders.length ? t.placeholders.join(",") : "-") },
      { header: "DESCRIPTION", get: (t) => t.description },
    ]) + "\n",
  );
}

async function cmdShow(positionals, flags) {
  const id = requireId(positionals, "show");
  const t = await api("GET", `/api/tasks/${encodeURIComponent(id)}`);
  const lines = [
    `id:        ${t.id}`,
    `workspace: ${t.workspace_id}`,
    `status:    ${t.status}${t.idle ? " (idle)" : ""}${t.conflict ? " (conflict)" : ""}`,
    `ci:        ${ciCell(t)}`,
  ];
  // Agent-liveness verdict (working/stalled/dead) for a live in_progress agent — read it
  // here instead of probing herdr panes / /proc / the spinner by hand.
  if (t.liveness) lines.push(`liveness:  ${t.liveness.state} — ${t.liveness.evidence}`);
  if (t.tags && t.tags.length) lines.push(`tags:      ${t.tags.join(", ")}`);
  if (t.allowlist && t.allowlist.length) lines.push(`allowlist: ${t.allowlist.join(", ")}`);
  if (t.blocked_by && t.blocked_by.length) {
    lines.push(`blocked_by: ${t.blocked_by.join(", ")}`);
    if (t.deadBlockers && t.deadBlockers.length) {
      lines.push(`  dead blockers (never merge): ${t.deadBlockers.join(", ")}`);
    }
  }
  if (t.question) lines.push(`\nawaiting answer to:\n${t.question}`);
  if (t.last_dispatch_error) lines.push(`dispatch error: ${t.last_dispatch_error}`);
  if (t.revert_reason) lines.push(`revert reason: ${t.revert_reason}`);
  if (t.ci_summary) lines.push(`\nCI:\n${t.ci_summary}`);
  if (t.summary) lines.push(`\nsummary:\n${t.summary}`);
  const notes = t.review_notes || t.review_note;
  if (notes) lines.push(`\nreview notes:\n${notes}`);
  return emit(flags, t, lines.join("\n") + "\n");
}

async function cmdApprove(positionals, flags) {
  const id = requireId(positionals, "approve");
  const r = await api("POST", `/api/tasks/${encodeURIComponent(id)}/approve`, {});
  // approve returns either the task view directly, or {task, conflictSentBack} /
  // {task, revertedOnRed} when the merge couldn't complete cleanly.
  let text;
  if (r.conflictSentBack) {
    text = `${id}: merge conflict — sent back to the agent for resolution\n`;
  } else if (r.revertedOnRed) {
    text = `${id}: merged then AUTO-REVERTED (post-merge verify failed) — now flagged\n`;
  } else {
    const task = r.task ?? r;
    text = `approved ${id} (${task.status})\n`;
  }
  return emit(flags, r, text);
}

// Confirm a release_mode major-bump task's merge — the human DOUBLE-CONFIRM ritual. Must
// be run TWICE CONSECUTIVELY (streak 0→1→2); the second lands the merge. Mirrors approve's
// response shape: {task, awaitingMajorConfirm} while still parked, the bare merged task
// view (carrying released_version) once it lands, or the conflict/revert flags.
async function cmdConfirmMajor(positionals, flags) {
  const id = requireId(positionals, "confirm-major");
  const r = await api("POST", `/api/tasks/${encodeURIComponent(id)}/confirm-major`, {});
  let text;
  if (r.conflictSentBack) {
    text = `${id}: merge conflict — sent back to the agent for resolution\n`;
  } else if (r.revertedOnRed) {
    text = `${id}: merged then AUTO-REVERTED (post-merge verify failed) — now flagged\n`;
  } else if (r.awaitingMajorConfirm) {
    const n = r.task?.major_confirm_count ?? 1;
    text = `${id}: major-version confirmation ${n}/2 — run confirm-major once more (consecutively) to merge\n`;
  } else {
    const task = r.task ?? r;
    const v = task.released_version ? ` (v${task.released_version})` : "";
    text = `confirmed ${id} — merged${v} (${task.status})\n`;
  }
  return emit(flags, r, text);
}

async function cmdReject(positionals, flags) {
  const id = requireId(positionals, "reject");
  const note = flags.message;
  if (!note) fail("reject: missing -m <note>");
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/reject`, { note });
  return emit(flags, t, `rejected ${id} → ${t.status} (agent will resume with your note)\n`);
}

async function cmdAnswer(positionals, flags) {
  const id = requireId(positionals, "answer");
  const answer = flags.message;
  if (!answer) fail("answer: missing -m <text>");
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/answer`, { answer });
  return emit(flags, t, `answered ${id} → ${t.status} (agent will resume with your answer)\n`);
}

// Structured plan-approval: approve a plan-preview task's proposed plan (the agent resumes
// to implement). An optional -m adds steering notes. Distinct from `answer` — it 409s unless
// the task is at the plan-approval step. See POST /api/tasks/:id/plan/approve.
async function cmdPlanApprove(positionals, flags) {
  const id = requireId(positionals, "plan-approve");
  const body = flags.message ? { note: flags.message } : {};
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/plan/approve`, body);
  const how = flags.message ? "approved with steering notes" : "approved";
  return emit(flags, t, `plan ${how} for ${id} → ${t.status} (agent will implement)\n`);
}

// Structured plan-rejection: send a proposed plan back for revision with required feedback
// (the agent re-proposes via propose_plan). See POST /api/tasks/:id/plan/reject.
async function cmdPlanReject(positionals, flags) {
  const id = requireId(positionals, "plan-reject");
  const note = flags.message;
  if (!note) fail("plan-reject: missing -m <feedback>");
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/plan/reject`, { note });
  return emit(flags, t, `plan rejected for ${id} → ${t.status} (agent will revise + re-propose)\n`);
}

async function cmdSpec(positionals, flags) {
  const id = requireId(positionals, "spec");
  // The spec is multi-line, so accept it via -m <text> OR piped on stdin (so the CTO
  // agent / operator can `butchr spec <id> < spec.md` or heredoc it).
  let spec = flags.message;
  if (!spec && !process.stdin.isTTY) {
    spec = (await Bun.stdin.text()).trim();
  }
  if (!spec) fail("spec: provide the spec via -m <text> or pipe it on stdin");
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/spec`, { spec });
  return emit(flags, t, `spec submitted for ${id} → ${t.status} (awaiting approval)\n`);
}

// Nudge a live build agent that has gone IDLE (the idle-handling action). A bare nudge
// sends "continue"; `-m <text>` sends guidance instead. The server re-checks liveness and
// auto-resumes a dead pane rather than poking it.
async function cmdNudge(positionals, flags) {
  const id = requireId(positionals, "nudge");
  const body = flags.message ? { text: flags.message } : {};
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/nudge`, body);
  const what = flags.message ? `guidance sent` : `sent 'continue'`;
  return emit(flags, t, `nudged ${id} → ${t.status} (${what})\n`);
}

async function cmdRequeue(positionals, flags) {
  const id = requireId(positionals, "requeue");
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/requeue`, {});
  return emit(flags, t, `requeued ${id} (${t.status})\n`);
}

async function cmdBlock(positionals, flags) {
  const id = requireId(positionals, "block");
  if (flags.on === undefined) fail("block: missing --on id,id (use --on '' to clear)");
  const blockedBy = parseIdList(flags.on);
  const t = await api("PUT", `/api/tasks/${encodeURIComponent(id)}/blocked_by`, {
    blocked_by: blockedBy,
  });
  const onStr = blockedBy.length ? blockedBy.join(", ") : "(cleared)";
  return emit(flags, t, `${id} blocked_by = ${onStr} → ${t.status}\n`);
}

async function cmdPriority(positionals, flags) {
  const id = requireId(positionals, "priority");
  if (positionals[1] === undefined) fail("priority: missing <N> (the integer priority)");
  const priority = parsePriority(positionals[1]);
  const t = await api("POST", `/api/tasks/${encodeURIComponent(id)}/priority`, { priority });
  return emit(flags, t, `${id} priority = ${t.priority} (${t.status})\n`);
}

// ---- offline DB snapshot / restore ----------------------------------------
// These two are the ONE exception to "thin REST client": a DB restore can't go
// through the running server (it holds the db open), so they operate directly on
// the filesystem via the shared logic in src/backup.ts. Importing that module is
// side-effect-free w.r.t. opening the db (it loads db.ts lazily), so neither
// command opens the live db.

/** Is a butchr server answering on BASE? Best-effort; false on any error. */
async function serverRunning() {
  try {
    const res = await fetch(BASE + "/health");
    return res.ok || res.status === 503; // any HTTP answer means it's up
  } catch {
    return false;
  }
}

async function cmdBackups(flags) {
  const backup = await import("../src/backup.ts");
  const list = backup.listBackups();
  return emit(
    flags,
    list,
    list.length === 0
      ? "(no snapshots found)\n"
      : table(list, [
          { header: "NAME", get: (b) => b.name },
          { header: "SIZE", get: (b) => `${Math.round(b.size / 1024)}KB` },
          { header: "MODIFIED", get: (b) => new Date(b.mtimeMs).toISOString() },
        ]) + "\n",
  );
}

async function cmdRestore(positionals, flags) {
  const target = positionals[0];
  if (!target) fail("restore: missing <file|latest>");
  if (!flags.force && (await serverRunning())) {
    fail(
      `a butchr server appears to be running at ${BASE} — stop it first ` +
        `(see CONTRIBUTING.md "Restart safely"), then re-run, or pass --force.`,
    );
  }
  const backup = await import("../src/backup.ts");
  let result;
  try {
    result = backup.restoreFromBackup(target);
  } catch (e) {
    fail(`restore: ${(e && e.message) || String(e)}`);
  }
  return emit(
    flags,
    result,
    `restored ${result.restored}\n  from: ${result.from}\n` +
      (result.backedUp ? `  previous db saved to: ${result.backedUp}\n` : "") +
      `Start butchr to pick up the restored database.\n`,
  );
}

async function cmdSelftest(flags) {
  // Parse --timeout <seconds> into ms (default left to the harness).
  let timeoutMs;
  if (flags.timeout !== undefined) {
    const secs = Number(flags.timeout);
    if (!Number.isFinite(secs) || secs <= 0) fail("selftest: --timeout must be a positive number of seconds");
    timeoutMs = Math.floor(secs * 1000);
  }
  if (!flags.json) {
    process.stdout.write(`butchr selftest — driving a throwaway probe through the full lifecycle\n`);
  }
  const result = await runSelftest({
    api,
    // Stage lines stream live during the (possibly long) wait; suppressed under --json.
    log: flags.json ? undefined : (msg) => process.stdout.write(msg + "\n"),
    dir: flags.workspace,
    merge: Boolean(flags.merge),
    timeoutMs,
  });
  emit(
    flags,
    result,
    result.ok
      ? `\nPASS — the butchr pipeline is healthy end-to-end.\n`
      : `\nFAIL — ${result.error ?? "see the stage table above"}\n`,
  );
  if (!result.ok) process.exit(1);
}

// ---- wait / restart (blocking ergonomics) ---------------------------------

/** Sleep helper for the polling loops below. */
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

// The terminal task states (mirrors src/db.ts isTerminal). `wait` fails fast if a task
// reaches one of these that ISN'T the awaited state — it'll never advance further.
const TERMINAL_STATES = new Set(["merged", "aborted", "rolled_back", "failed"]);

/** Parse a `--timeout/--interval <seconds>` flag into ms, or fall back to a default. */
function parseSeconds(raw, name, fallbackMs) {
  if (raw === undefined) return fallbackMs;
  const secs = Number(raw);
  if (!Number.isFinite(secs) || secs <= 0) fail(`${name} must be a positive number of seconds`);
  return Math.floor(secs * 1000);
}

// Block until a task reaches `--until <state>` (replacing hand-rolled curl+sleep loops).
// `<state>` matches the task's status, plus the synthetic `idle` (a running agent gone
// quiet). Exits 0 when reached; non-zero on a timeout or if the task lands in a DIFFERENT
// terminal state first. Polls GET /api/tasks/:id every `--interval` (default 2s).
async function cmdWait(positionals, flags) {
  const id = requireId(positionals, "wait");
  const until = (flags.until ?? "").trim();
  if (!until) fail("wait: missing --until <state>");
  const timeoutMs = parseSeconds(flags.timeout, "wait: --timeout", 600000);
  const intervalMs = parseSeconds(flags.interval, "wait: --interval", 2000);
  const deadline = Date.now() + timeoutMs;
  // `idle` is a flag on a running agent, not a status — match it explicitly.
  const reached = (t) => (until === "idle" ? t.status === "in_progress" && t.idle : t.status === until);
  for (;;) {
    const t = await api("GET", `/api/tasks/${encodeURIComponent(id)}`);
    if (reached(t)) {
      return emit(flags, t, `${id} reached ${until} (status=${t.status}${t.idle ? ", idle" : ""})\n`);
    }
    // A terminal state that isn't what we're waiting for → it will never advance; bail now.
    if (TERMINAL_STATES.has(t.status) && t.status !== until) {
      flags.json && printJson(t);
      fail(`wait: ${id} reached terminal state '${t.status}' while waiting for '${until}'`);
    }
    if (Date.now() >= deadline) {
      flags.json && printJson(t);
      fail(`wait: timed out after ${Math.round(timeoutMs / 1000)}s waiting for ${id} to reach '${until}' (status=${t.status})`);
    }
    await sleep(Math.min(intervalMs, Math.max(0, deadline - Date.now())));
  }
}

// Fetch /health directly (it 503s when degraded without an `error` body, so don't route it
// through api()). Returns the parsed body + http status, or null if unreachable.
async function fetchHealth() {
  try {
    const res = await fetch(BASE + "/health");
    return { body: await res.json(), status: res.status };
  } catch {
    return null;
  }
}

// Restart the butchr server (POST /api/restart → the server SIGTERMs itself; its supervisor
// relaunches it). --verify blocks until /health answers healthy from a FRESH process (a
// different pid than before the restart), then reports the db/tick/herdr self-check. Without
// --verify it just fires the restart and returns. Exits non-zero if --verify times out.
async function cmdRestart(flags) {
  const before = await fetchHealth();
  const oldPid = before?.body?.pid ?? null;
  const r = await api("POST", "/api/restart", {});
  if (!flags.verify) {
    return emit(flags, r, `restart requested (pid ${r.pid}, v${r.version}); server is going down + relaunching\n`);
  }
  const timeoutMs = parseSeconds(flags.timeout, "restart: --timeout", 60000);
  const deadline = Date.now() + timeoutMs;
  // Wait for a healthy /health from a NEW process: status 200 (db ok + tick alive) AND a pid
  // that changed from before the restart (so we don't read the old process on its way down).
  for (;;) {
    await sleep(1000);
    const h = await fetchHealth();
    if (h && h.status === 200 && h.body?.pid && (oldPid === null || h.body.pid !== oldPid)) {
      const herdrNote = h.body.herdr?.reachable ? "" : " (warning: herdr unreachable)";
      return emit(
        flags,
        { restarted: true, ...h.body },
        `restarted ✓ — healthy (pid ${h.body.pid}, v${h.body.version}, db ok, tick alive)${herdrNote}\n`,
      );
    }
    if (Date.now() >= deadline) {
      fail(`restart: server did not come back healthy within ${Math.round(timeoutMs / 1000)}s — check the supervisor / logs`);
    }
  }
}

// ---- entrypoint -----------------------------------------------------------

async function main() {
  const argv = process.argv.slice(2);
  const command = argv[0];
  const { positionals, flags } = parseArgs(argv.slice(1));

  if (!command || command === "-h" || command === "--help" || flags.help) {
    process.stdout.write(HELP);
    return;
  }

  switch (command) {
    case "health":
      return cmdHealth(flags);
    case "dashboard":
      return cmdDashboard(flags);
    case "gate":
      return cmdGate(positionals, flags);
    case "ls":
      return cmdLs(flags);
    case "new":
      return cmdNew(positionals, flags);
    case "templates":
      return cmdTemplates(flags);
    case "show":
      return cmdShow(positionals, flags);
    case "approve":
      return cmdApprove(positionals, flags);
    case "confirm-major":
      return cmdConfirmMajor(positionals, flags);
    case "reject":
      return cmdReject(positionals, flags);
    case "answer":
      return cmdAnswer(positionals, flags);
    case "plan-approve":
      return cmdPlanApprove(positionals, flags);
    case "plan-reject":
      return cmdPlanReject(positionals, flags);
    case "wait":
      return cmdWait(positionals, flags);
    case "restart":
      return cmdRestart(flags);
    case "spec":
      return cmdSpec(positionals, flags);
    case "requeue":
      return cmdRequeue(positionals, flags);
    case "nudge":
      return cmdNudge(positionals, flags);
    case "block":
      return cmdBlock(positionals, flags);
    case "priority":
      return cmdPriority(positionals, flags);
    case "selftest":
      return cmdSelftest(flags);
    case "backups":
      return cmdBackups(flags);
    case "restore":
      return cmdRestore(positionals, flags);
    default:
      fail(`unknown command: ${command}\nRun 'butchr --help' for usage.`);
  }
}

main().catch((e) => {
  fail(e instanceof ApiError ? e.message : (e && e.message) || String(e));
});
