#!/usr/bin/env bash
# The four silent-failure assertions (RFC §4.3), run against a built front-end directory.
#
# Each of the four failures below EXITS 0, BOOTS, AND IS STILL WRONG. None produces a build
# error, and none is visible to a layout or size assertion. These four assertions are the entire
# defence. Do not delete them as "redundant with the build" — the build is exactly what cannot
# see them. `test/fe-artifact-assertions.test.ts` proves each one still fires.
#
# Assertion 3 is three greps, not one, and the third was added in Phase 3 after the first build with
# React in it PROVED the other two miss `--minify`-without-NODE_ENV. See its comment block.
#
# Assertion 4 defends against an ORPHANED token: a `var(--lp-*)` whose name is defined NOWHERE in
# the bundle. The declaration is then invalid at computed-value time and is dropped — and an
# INHERITED property like `color` silently takes its parent's value. Not hypothetical:
# `@launchpad-ui/components@0.21.0` var()s two names (`--lp-color-text-ui-secondary-base`,
# `--lp-color-text-ui-tertiary`) that `@launchpad-ui/tokens@0.16.0` never defines. The build, the
# typecheck, and the whole gate were green. Assertion 1 could not see it: it counts DEFINITIONS,
# and 380 of them are present while two USED names resolve to nothing.
#
# Usage:  bun run assert:fe <dist-dir>   (scripts/ci must invoke it this way — see scripts/ci)
set -euo pipefail

DIST="${1:-}"
if [ -z "$DIST" ] || [ ! -d "$DIST" ]; then
  echo "usage: scripts/assert-fe-artifact <dist-dir>" >&2
  exit 2
fi

shopt -s nullglob
if [ ! -f "$DIST/index.html" ]; then
  echo "FE ARTIFACT: $DIST is not a built front end (no index.html)" >&2
  exit 1
fi

# The CSS is the set index.html ACTUALLY REFERENCES, not `$DIST/*.css`.
#
# This is not fastidiousness; the glob is unsound and it was measured. `bun build --outdir` does
# NOT clean its output directory, and every build names its assets by content hash. So a rebuild
# after a source change LEAVES THE PREVIOUS BUNDLE IN PLACE under its old hash, and a glob unions
# the two. Dropping `@launchpad-ui/tokens/themes.css` from the entry takes the real stylesheet
# from 377 `--lp-*` definitions to 149 — comfortably red — but the stale 377-definition CSS from
# the last build is still sitting in dist/, so the union is 377 and assertion 1 PASSES. Observed,
# not theorised: the gate exited 0 on a genuinely unstyled artifact.
#
# `build:fe` now `rm -rf dist` first, which fixes the cause. This fixes the assertion, because an
# assertion whose correctness depends on somebody else having cleaned up is not an assertion. The
# entry HTML is the only thing that says which bytes the browser will load.
# Both `./name` and `/name` are accepted. `build:fe` passes `--public-path=/`, so bun emits
# ABSOLUTE refs (a relative ref would resolve against the wrong base under serveStatic's SPA
# fallback at `/task/<id>`); a plain `bun build` with no --public-path emits `./name`. Matching
# only one form makes this script's own zero-glob guard fire on a perfectly good artifact.
mapfile -t REFS < <(grep -ohE '(src|href)="\.?/[^"]+"' "$DIST/index.html" | sed -E 's/^[a-z]+="\.?\///; s/"$//')
CSS=()
for r in "${REFS[@]}"; do
  [ "${r##*.}" = "css" ] || continue
  if [ ! -f "$DIST/$r" ]; then
    echo "FE ARTIFACT: $DIST/index.html references ./$r, which does not exist — stale or partial build." >&2
    exit 1
  fi
  CSS+=("$DIST/$r")
done

# The JS is every .js in the tree, NOT just the referenced entry: a lazily-imported chunk is not
# named in index.html and is exactly as capable of carrying React's development build. Sourcemaps
# are excluded — `.js.map` does not match `*.js`.
JS=("$DIST"/*.js)

# A glob matching zero files must FAIL, never silently pass: an assertion that runs over no
# input is an assertion that cannot fail, which is worse than no assertion at all.
if [ "${#CSS[@]}" -eq 0 ] || [ "${#JS[@]}" -eq 0 ]; then
  echo "FE ARTIFACT: $DIST is not a built front end (index.html must reference a .css; need at least one .js)" >&2
  exit 1
fi

# --- assertion 1: TOKENS ---------------------------------------------------------------------
# @launchpad-ui/components' CSS var()s ~187 `--lp-*` names and DEFINES ONE (a component-local
# --lp-button-padding). Every colour, radius and spacing resolves to nothing and the page renders
# UNSTYLED. The fix is two imports in the entry module — `@launchpad-ui/tokens/index.css` and
# `.../themes.css` — and this is what proves they are still there.
#
# The threshold is 300, not an exact count: an exact count would go red on every
# `@launchpad-ui/tokens` bump for no reason. Measured against the real 0.16.0 package:
#
#   both sheets        380 definitions   <- the only healthy state
#   index.css only     149               <- red: the colour VALUES live in themes.css
#   themes.css only    228               <- red
#   neither              0               <- red (and grep exits 1 — see `|| true` below)
#
# That 380 DRIFTS — it moves with every `@launchpad-ui/tokens` bump, and with any local `--lp-*`
# definition (public/style.css's two-token upstream-bug shim took it from 378 to 380). It is a
# smell test, never an assertion. The loose threshold is exactly what keeps a bump green.
#
# So the guard is not merely 0-vs-377: it catches dropping EITHER sheet, which is the mistake an
# author is actually likely to make. 300 sits above 228 and far below 377.
#
# `|| true` is load-bearing: grep exits 1 on ZERO matches, and under `set -o pipefail` that
# would abort the script here — going red with an EMPTY diagnostic, in the one case the
# diagnostic matters most (0 definitions == the failure being guarded).
DEFS=$({ grep -ohE -- '--lp-[a-z0-9-]+:' "${CSS[@]}" || true; } | sort -u | wc -l)
if [ "$DEFS" -le 300 ]; then
  echo "FE ARTIFACT: token CSS missing — only $DEFS --lp-* definitions in the bundle (expected >300)." >&2
  echo "  The page will render UNSTYLED while the build exits 0. The entry module must import BOTH" >&2
  echo "  '@launchpad-ui/tokens/index.css' and '@launchpad-ui/tokens/themes.css'." >&2
  echo "  ('@launchpad-ui/tokens/style.css' does not exist — do not guess the specifier.)" >&2
  exit 1
fi

# --- assertion 2: SPRITE ---------------------------------------------------------------------
# Icon emits <use href="#lp-icon-x">, a document-local reference. Without the sprite spliced into
# <body>, every icon renders BLANK while keeping its 20x20 box — invisible to any layout test.
if ! grep -q 'id="lp-icon-' "$DIST/index.html"; then
  echo "FE ARTIFACT: icon sprite not inlined into <body> of $DIST/index.html." >&2
  echo "  Every icon renders BLANK while keeping its 20x20 layout box. Run scripts/inline-sprite." >&2
  exit 1
fi

# --- assertion 3: PRODUCTION BUILD -----------------------------------------------------------
# `--production` is opt-in, and it does two things: it minifies, and it sets NODE_ENV=production,
# which is what selects React's PRODUCTION bundle over its DEVELOPMENT one (1.61 MB vs 0.46 MB,
# with dev-mode checks running in the operator's browser). Nothing warns.
#
# It is checked THREE ways, and none of the three subsumes the others. Measured against the real
# Phase 3 bundle (React + @launchpad-ui in the graph), on bun 1.3.11:
#
#   flags            bytes   indented lines   react-dom.development   jsxDEV
#   --production     400 KB          ~0                 0                0     <- the only healthy state
#   --minify         604 KB          ~0                 0               55     <- RED, and only check 3 sees it
#   (none)         1,400 KB      26,983                 1               60     <- RED
#
# 1. MINIFICATION. `--production` is `--minify` plus `NODE_ENV=production`, so this catches the flag
#    being dropped outright. It was the load-bearing check through Phases 1-2, when public/ imported
#    no React at all and the greps below could not match anything.
#
# 2. `react-dom.development`. Real work since Phase 3 put React in the graph: an unflagged build
#    carries it. It CANNOT, however, catch `--minify` without NODE_ENV — bun's minifier resolves
#    react-dom to its production copy anyway, and that row above is measured, not assumed. The
#    comment that used to live here claimed the opposite. It was wrong.
#
# 3. `jsxDEV`. This is what actually closes the `--minify`-without-NODE_ENV hole. React's DEVELOPMENT
#    JSX runtime (`react/jsx-dev-runtime`) survives minification with its warning strings and 32
#    `react.dev/link` doc URLs intact — 200 KB of dev-mode checks running in the operator's browser,
#    through a bundle that is minified and carries the production react-dom. Nothing else sees it.
INDENTED=$({ grep -chE '^[[:space:]]{2,}[^[:space:]]' "${JS[@]}" || true; } | awk '{s+=$1} END {print s+0}')
if [ "$INDENTED" -ge 100 ]; then
  echo "FE ARTIFACT: the JS bundle is NOT minified — $INDENTED indented lines (a minified bundle has ~0)." >&2
  echo "  Did --production get dropped from build:fe? It also sets NODE_ENV=production, which is what" >&2
  echo "  selects React's 0.46 MB production build over its 1.61 MB development one." >&2
  exit 1
fi
if grep -q 'react-dom.development' "${JS[@]}"; then
  echo "FE ARTIFACT: React DEVELOPMENT build in the output — NODE_ENV was not production." >&2
  echo "  That is 1.61 MB instead of 0.46 MB, with dev-mode checks running in the browser." >&2
  echo "  --production sets NODE_ENV; --minify alone does not." >&2
  exit 1
fi
if grep -q 'jsxDEV' "${JS[@]}"; then
  echo "FE ARTIFACT: React's DEVELOPMENT JSX runtime in the output — NODE_ENV was not production." >&2
  echo "  A minified bundle hides this: react-dom resolves to its production copy, so the grep above" >&2
  echo "  stays green while react/jsx-dev-runtime ships 200 KB of dev-mode checks to the browser." >&2
  echo "  Use --production, which sets NODE_ENV. --minify alone does NOT." >&2
  exit 1
fi

# --- assertion 4: ORPHANED TOKENS ------------------------------------------------------------
# Assertion 1 counts DEFINITIONS. It cannot see a token that is USED and defined nowhere: 380
# definitions are present, the sheet loads, and two `color:` declarations are still invalid at
# computed-value time. An invalid var() does not fall back to a sane default and does not warn —
# the declaration is dropped, and for an INHERITED property (`color`, `font-family`, …) the
# element silently takes its PARENT's value. That is how `--lp-color-text-ui-secondary-base` and
# `--lp-color-text-ui-tertiary` shipped: referenced by @launchpad-ui/components@0.21.0, defined by
# nothing, invisible to the build, the typecheck, and every layout assertion.
#
# Over the referenced CSS only — never `$DIST/*.css` (see the CSS array above), and never the JS
# bundle, whose `--lp-*` strings are not CSS custom-property references.
#
# FALLBACKS ARE EXEMPT, BY DESIGN. `var(--x, 0px)` is a deliberate may-be-undefined: if `--x` is
# missing the fallback resolves and the declaration is valid. The USED pattern therefore requires
# the closing `)` immediately after the name, which matches only a var() with NO fallback. Today's
# bundle has exactly one fallback-guarded name (`--lp-button-padding`, which is also defined — so
# do not let that coincidence convince you the exemption works; test/fe-artifact-assertions.test.ts
# exercises an UNDEFINED fallback-guarded name directly). Without this, the first legitimate
# fallback anyone adds reddens the gate for no reason.
#
# NESTED var() falls out correctly, and it looks like a bug, so: `var(--lp-a, var(--lp-b))` exempts
# `--lp-a` (it has a fallback) while the inner `var(--lp-b)` matches as a hard usage — correct,
# because nothing is behind `--lp-b` and an undefined `--lp-b` invalidates the whole declaration.
# `var(--lp-a, var(--lp-b, red))` exempts both, and `red` always resolves. The rule the pattern
# actually implements is "a var() with no fallback behind it must resolve."
#
# The DEFINITION pattern is anchored to NEITHER `:root` NOR a line start. Definitions inside
# `@media`, `@supports`, and `[data-theme='dark']` blocks are real definitions, and the bundle is
# minified onto essentially ONE line — a line-oriented regex would see the whole sheet as a single
# match and collect nothing. Both patterns use BOUNDED character classes: an unbounded negated
# class (`[^)]*`) backtracking across 150 KB with no newline hangs for minutes, and this script
# runs on every single gate invocation in the repo.
#
# `|| true` on EVERY grep, for the same reason as assertion 1: grep exits 1 on ZERO matches, which
# under `set -o pipefail` aborts with an EMPTY diagnostic in the case the diagnostic matters most.
# BOTH stages of each pipeline need it, not just the first — that is not paranoia, it was observed:
# guarding only the outer grep still let the zero-usage case abort silently with exit 1 and no
# message, and the `no var(--lp-*) usages` test below is what caught it.
USED=$({ grep -ohE -- 'var\([[:space:]]*--lp-[a-z0-9-]+[[:space:]]*\)' "${CSS[@]}" || true; } \
  | { grep -oE -- '--lp-[a-z0-9-]+' || true; } | sort -u)
DEFINED=$({ grep -ohE -- '--lp-[a-z0-9-]+[[:space:]]*:' "${CSS[@]}" || true; } \
  | { grep -oE -- '--lp-[a-z0-9-]+' || true; } | sort -u)

# Zero usages must FAIL, never vacuously pass — the same argument the CSS/JS globs make above. A
# real bundle uses the tokens it defines (240 hard usages today); zero means the stylesheet is not
# what this script thinks it is, and an assertion that runs over no input cannot fail.
if [ -z "$USED" ]; then
  echo "FE ARTIFACT: no var(--lp-*) usages in the referenced CSS — the orphan-token check would" >&2
  echo "  pass vacuously. An assertion that runs over no input cannot fail. Is this a real bundle?" >&2
  exit 1
fi

ORPHANS=$(comm -23 <(printf '%s\n' "$USED") <(printf '%s\n' "$DEFINED"))
if [ -n "$ORPHANS" ]; then
  {
    echo "FE ARTIFACT: orphaned --lp-* token(s) — used via var(), defined NOWHERE in the bundle:"
    printf '%s\n' "$ORPHANS" | sed 's/^/    /'
    echo "Each declaration using one of these is INVALID AT COMPUTED-VALUE TIME. It is dropped, with"
    echo "no error and no warning: the build exits 0 and the page boots. The property then falls back"
    echo "silently — for an INHERITED property such as 'color' that means the element takes its"
    echo "PARENT's value, which is why this is invisible to a layout or size assertion."
    echo "Either define the name (see the upstream-bug shim in public/style.css) or, if it is"
    echo "deliberately optional, give the var() a fallback: var(--lp-x, <default>)."
  } >&2
  exit 1
fi
USES=$(printf '%s\n' "$USED" | wc -l)

echo "FE ARTIFACT: ok — $DEFS --lp-* token definitions, $USES used and all defined, sprite inlined, minified production bundle."
