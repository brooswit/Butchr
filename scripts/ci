#!/usr/bin/env bash
set -euo pipefail
# deps. butchr runs this script in the task's git WORKTREE, which has no node_modules, so the
# typecheck below would otherwise have nothing to run. --frozen-lockfile makes a lockfile that
# disagrees with package.json a RED BUILD rather than a silent resolve against a tree nobody has
# run (RFC §4.4). It is safe on every post-release branch: bun.lock does NOT record the root
# package.json `version`, so butchr's release bump leaves the lockfile byte-identical and this
# still exits 0 (RFC Errata E1, re-verified against the real lockfile in this commit).
bun install --frozen-lockfile
# build + test (byte-exact replica of the retired gate_cmd)
bun build src/index.ts --target bun --outfile /dev/null
# typecheck. `bun build` above performs ZERO type checking — it strips the annotations and emits.
# Nothing had ever run `tsc` against this repo, and `src/` had 21 real type errors when it first
# did (RFC §13.4). This is the step that makes the types mean anything.
#
#   --bun is REQUIRED, not stylistic. `bunx tsc` execs node_modules/.bin/tsc, whose shebang is
#   `#!/usr/bin/env node`; this host's node is v12.22.9 and TypeScript 5.9's emitted code uses
#   `??`, so plain `bunx tsc` dies with `SyntaxError: Unexpected token '?'` before it typechecks a
#   single file. `--bun` forces the bun runtime. (RFC Errata E2, re-verified on this host.)
#
#   -p is explicit, and it is passed TWICE. A bare `tsc` reads ./tsconfig.json, whose `include`
#   is ["src"] — it would never look at public/ at all, silently typechecking half of what this
#   step promises. src/ and public/ CANNOT share one config, and the blocker is `lib`, not JSX
#   (RFC §5.5/§13.2, re-verified on this host): public/ needs `lib: DOM`, and DOM in src/ BREAKS
#   `for await (… of Bun.stdin.stream())` in channel.ts (TS2504 — lib.dom's ReadableStream is not
#   async-iterable) and MASKS mcp.ts's `await req.json()` (`unknown` under bun-types, `any` under
#   lib.dom's Request). Wrong in both directions, so: two configs, two invocations.
#
# ~10s together (src/ ~6.0s, public/ ~4.0s), NOT the ~100ms the old front-end rules cost. That
# retires the ordering rationale those rules were written under ("FE first, it's nearly free").
# The typecheck still runs before the bundle and the suite, on a different justification: it is
# the step most likely to catch a real error, and unlike any bundle it reads EVERY file matched by
# `include` — reachable from an entry point or not. That is how it REPLACES the orphan-module rule
# the old per-file parse loop provided.
#
#   Replaces, not strictly strengthens. Be precise about what is lost: through Phases 1-3 public/
#   is still 19 vanilla .js modules, and tsconfig.public.json sets `allowJs` WITHOUT `checkJs`, so
#   an orphan .js file's TYPE errors are NOT reported. For syntax and module resolution — which is
#   all the retired loop ever checked — this is exactly as strong, over the same file set. It only
#   becomes stronger when Phase 4 lands .tsx. No coverage is given up today; none is gained either.
#
# It stays behind `bun build src/index.ts` (~1s) so an outright broken backend still fails fast,
# and ahead of `bun test ./test`, which dominates everything by orders of magnitude.
bunx --bun tsc --noEmit -p tsconfig.json         # src/    — bun target, no DOM
bunx --bun tsc --noEmit -p tsconfig.public.json  # public/ — browser target, DOM, JSX
# front-end bundle. This is the REAL production build, into the REAL dist/ (gitignored), via the
# exact command `bun start` runs — so the gate proves the artifact the operator will be served,
# and `bun test ./test` below gets a dist/ to exercise serveStatic against.
#
# `--outdir`, NEVER `--outfile`. @launchpad-ui's JS imports its own CSS on line 1, so every build
# is multi-output, and `bun build public/index.html --outfile /dev/null` exits 1 with
# `error: cannot write multiple output files without an output directory`. The retired FE rules
# used --outfile; they could not have survived the first CSS import.
#
# "It builds" is the FE validation for resolution and syntax ONLY. It proves nothing about the
# three ways this front end fails while exiting 0 — hence the next line, which is not optional.
bun run build:fe
# the three silent-failure assertions (RFC §4.3). Spelled `bun run assert:fe`, NEVER
# `scripts/assert-fe-artifact` directly: test/changelog-header-drop.test.ts reads THIS FILE's text
# and executes it against temp git fixtures, stripping top-level `/^bunx?\s/` lines so the gate
# does not recursively rebuild and re-run the suite inside a fixture. A step invoked by any other
# command is not stripped, so it would run in a fixture that has no dist/ and turn all 8 of that
# file's CHANGELOG-guard tests red. Do not widen the strip pattern to cover `scripts/` — that
# would silently disarm every future gate step. Route new steps through package.json instead.
bun run assert:fe dist
bun test ./test
# changelog rule: a CODE change must update CHANGELOG.md (docs-only diffs EXEMPT)
BASE="${BUTCHR_BASE_REF:-}"
if [ -z "$BASE" ]; then BASE="origin/main"; fi
if ! git rev-parse --verify "$BASE" >/dev/null 2>&1; then BASE="main"; fi
FILES="$(git diff --name-only "$BASE"...HEAD 2>/dev/null || true)"
if [ -n "$FILES" ]; then
  NONDOCS="$(printf '%s\n' "$FILES" | grep -viE '(\.(md|mdx|txt)$|^docs/)' || true)"
  if [ -n "$NONDOCS" ] && ! printf '%s\n' "$FILES" | grep -qx 'CHANGELOG.md'; then
    echo "CHANGELOG.md not updated — a code change must add a changelog entry" >&2
    exit 1
  fi
fi
# rebase-race rule: a branch only ever ADDS to [Unreleased]. It never legitimately deletes a
# released version header, so a removed `## [<digit>...]` line is always the rebase silently
# dropping a released section and orphaning its bullets. The pathspec is REQUIRED — docs in
# this repo quote changelog headers, and an unscoped diff would trip on them. `[Unreleased]`
# starts with a letter, so its own header line can never match.
DROPPED="$(git diff "$BASE"...HEAD -- CHANGELOG.md 2>/dev/null | grep -E '^-## \[[0-9]' || true)"
if [ -n "$DROPPED" ]; then
  {
    echo "CHANGELOG REBASE-RACE: this diff DELETES a released version header from CHANGELOG.md."
    echo "The rebase dropped a released section; its bullets are now orphaned under [Unreleased]."
    echo "Dropped header line(s):"
    printf '%s\n' "$DROPPED" | sed 's/^/    /'
    echo "Rebase onto the latest main and re-add the header(s). A branch only ADDS to [Unreleased]."
  } >&2
  exit 1
fi
